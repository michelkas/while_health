# While Health - Environment Variables
# Production-ready configuration

# ============================================
# SECURITY SETTINGS
# ============================================
DEBUG=True
SECRET_KEY=your-secret-key-here-min-50-chars-use-django-generate
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,https://yourdomain.com

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/while_health

# ============================================
# CACHING
# ============================================
# Local Redis default port; fallback to DB cache on failure
REDIS_URL=redis://127.0.0.1:6379/1

# ============================================
# LOGGING
# ============================================
DJANGO_LOG_LEVEL=INFO

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# ============================================
# EMAIL (Optional)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ============================================
# MEDICAL DATA RETENTION (RGPD)
# ============================================
PATIENT_DATA_RETENTION_DAYS=2555  # 7 years RGPD compliance
